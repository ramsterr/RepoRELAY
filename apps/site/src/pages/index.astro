---
import Base from "../layouts/Base.astro";

const examples = [
  "fastapi/fastapi",
  "django/django",
  "pallets/flask",
  "psf/requests",
  "facebook/react",
  "vuejs/core",
  "angular/angular",
  "nestjs/nest",
];
---

<Base>
  <h1>find repos worth your time</h1>
  <p class="subtitle">
    built with a 5-stage recommender — pure Postgres + pgvector, no ML training
  </p>

  <div class="search-bar">
    <input
      type="text"
      id="repo-input"
      placeholder="owner/name — e.g. fastapi/fastapi"
      autofocus
    />
    <button type="button" id="search-btn">search</button>
  </div>

  <p class="section-label">try one of these</p>
  <div class="example-repos">
    {examples.map((r) => <a href={`/repo/${r}`}>{r}</a>)}
  </div>

  <div class="actions" style="margin-top: 2rem;">
    <a href="/explore" class="btn btn-outline" style="display:inline-block;">
      surprise me
    </a>
  </div>
</Base>

<script is:inline>
  var btn = document.getElementById("search-btn");
  var input = document.getElementById("repo-input");
  if (btn && input) {
    btn.addEventListener("click", function () {
      var val = input.value.trim();
      if (val && val.includes("/")) {
        window.location.href = "/repo/" + val;
      }
    });
    input.addEventListener("keydown", function (e) {
      if (e.key === "Enter") {
        e.preventDefault();
        var val = input.value.trim();
        if (val && val.includes("/")) {
          window.location.href = "/repo/" + val;
        }
      }
    });
  }
</script>
